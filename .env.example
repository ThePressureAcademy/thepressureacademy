# ─────────────────────────────────────────────────────────────────────────────
# Mastery Method Portal — Required Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Set these in the Vercel dashboard: Project → Settings → Environment Variables
# Do NOT commit real values to the repository.
# ─────────────────────────────────────────────────────────────────────────────

# Session signing secret
# A random string of 32+ characters used to sign session cookies.
# Generate one at: https://generate-secret.vercel.app/32
# If this changes, all existing sessions are invalidated (families need to re-activate).
SESSION_SECRET=replace-with-a-random-32-character-string-here

# Portal invite tokens (comma-separated)
# Each token is a unique string issued to one enrolled family.
# The family's invite link is: https://thepressureacademy.com/api/auth/activate?token=TOKEN
# To revoke a family's access: remove their token from this list and redeploy.
# See docs/PORTAL_ACCESS_ADMIN.md for the full workflow.
PORTAL_INVITE_TOKENS=example-token-smith-family,example-token-jones-family
