# ─────────────────────────────────────────────────────────────────────────────
# Mastery Method Portal — Required Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Set these in the Vercel dashboard: Project → Settings → Environment Variables
# Do NOT commit real values to the repository.
# ─────────────────────────────────────────────────────────────────────────────

# Session signing secret
# A random string of 32+ characters used to sign session cookies.
# Generate one at: https://generate-secret.vercel.app/32
# If this changes, all existing sessions are invalidated (families need to re-activate).
SESSION_SECRET=replace-with-a-random-32-character-string-here

# Portal invite tokens (comma-separated)
# Each token is a unique string issued to one enrolled family.
# The family's invite link is: https://thepressureacademy.com/api/auth/activate?token=TOKEN
# To revoke a family's access: remove their token from this list and redeploy.
# See docs/PORTAL_ACCESS_ADMIN.md for the full workflow.
PORTAL_INVITE_TOKENS=example-token-smith-family,example-token-jones-family

# ─────────────────────────────────────────────────────────────────────────────
# Commerce integration boundaries — NOT CONNECTED YET
# ─────────────────────────────────────────────────────────────────────────────
# Nothing in the repo reads these at runtime today. They document the exact
# credentials each adapter needs so going live is a config change, not a build.
# Client-safe values are injected via window.__TPA_SHOPIFY / window.__TPA_KLAVIYO
# (see js/lib/shopify-client.js and js/lib/klaviyo-events.js).
# Secret values stay server-side in Vercel env — never shipped to the browser.

# Shopify headless storefront (adapter: js/lib/shopify-client.js)
# SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
# SHOPIFY_STOREFRONT_API_TOKEN=public-storefront-token
# SHOPIFY_ADMIN_API_TOKEN=server-side-only-admin-token

# Checkout provider (set exactly one; also set checkout.provider in js/config/commerce.js)
# NOTE: Stripe Payment Links (the first-dollar seminar path) need NO keys here.
# The link URL goes directly into js/config/funnels.js (checkoutUrl) — see
# docs/PRESSURE_ACADEMY_FIRST_SEMINAR_LAUNCH_GUIDE.md. The keys below are for a
# later server-side phase (webhooks/fulfilment), not for Payment Link redirects.
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# SAMCART_API_KEY=...

# Klaviyo retention (adapter: js/lib/klaviyo-events.js)
# KLAVIYO_PUBLIC_KEY=site-public-key
# KLAVIYO_PRIVATE_KEY=server-side-only-private-key

# Logistics / freight (adapter: js/lib/logistics-providers.js)
# SHIPSTATION_API_KEY=...
# SHIPSTATION_API_SECRET=...
# FREIGHT_PARTNER_ACCOUNT_ID=...
