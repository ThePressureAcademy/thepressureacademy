{
  "functions": {
    "api/portal-serve.js": {
      "includeFiles": "mastery-method/portal/**"
    }
  },
  "rewrites": [
    {
      "source": "/mastery-method/portal/dashboard",
      "destination": "/api/portal-serve?page=dashboard"
    },
    {
      "source": "/mastery-method/portal/dashboard/:path*",
      "destination": "/api/portal-serve?page=dashboard"
    },
    {
      "source": "/mastery-method/portal/library",
      "destination": "/api/portal-serve?page=library"
    },
    {
      "source": "/mastery-method/portal/library/:path*",
      "destination": "/api/portal-serve?page=library"
    },
    {
      "source": "/mastery-method/portal/module",
      "destination": "/api/portal-serve?page=module"
    },
    {
      "source": "/mastery-method/portal/module/:path*",
      "destination": "/api/portal-serve?page=module"
    },
    {
      "source": "/mastery-method/portal/account",
      "destination": "/api/portal-serve?page=account"
    },
    {
      "source": "/mastery-method/portal/account/:path*",
      "destination": "/api/portal-serve?page=account"
    },
    {
      "source": "/mastery-method/portal/progress",
      "destination": "/api/portal-serve?page=progress"
    },
    {
      "source": "/mastery-method/portal/progress/:path*",
      "destination": "/api/portal-serve?page=progress"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    },
    {
      "source": "/mastery-method/portal/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "private, no-cache, no-store"
        },
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    }
  ]
}
