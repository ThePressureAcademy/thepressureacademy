{
  "functions": {
    "api/portal-serve.js": {
      "includeFiles": "mastery-method/portal/**"
    }
  },
  "routes": [
    {
      "src": "^/mastery-method/portal/dashboard(?:/.*)?$",
      "dest": "/api/portal-serve?page=dashboard"
    },
    {
      "src": "^/mastery-method/portal/library(?:/.*)?$",
      "dest": "/api/portal-serve?page=library"
    },
    {
      "src": "^/mastery-method/portal/module(?:/.*)?$",
      "dest": "/api/portal-serve?page=module"
    },
    {
      "src": "^/mastery-method/portal/account(?:/.*)?$",
      "dest": "/api/portal-serve?page=account"
    },
    {
      "src": "^/mastery-method/portal/progress(?:/.*)?$",
      "dest": "/api/portal-serve?page=progress"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    },
    {
      "source": "/mastery-method/portal/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "private, no-cache, no-store"
        },
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        },
        {
          "key": "Permissions-Policy",
          "value": "display-capture=()"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "no-referrer"
        }
      ]
    }
  ]
}
